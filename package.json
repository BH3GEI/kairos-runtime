{
  "name": "memoh-lite",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:embed": "bun run src/test-embed.ts",
    "dev": "concurrently \"bun run dev:state\" \"bun run dev:enclave\"",
    "dev:state": "AGENT_ENCLAVE_TARGET=127.0.0.1:50051 bun run --watch src/index.ts",
    "dev:enclave": "bun run src/agent/enclave/server.ts",
    "proto:gen:vfs": "grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/storage/vfs/generated --ts_proto_opt=esModuleInterop=true,env=node,forceLong=number,useExactTypes=false,outputServices=nice-grpc,outputServices=generic-definitions -I src/vfs/proto src/vfs/proto/vfs.proto",
    "proto:gen": "bun run proto:gen:vfs"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@mariozechner/pi-agent-core": "^0.54.0",
    "@mariozechner/pi-ai": "^0.54.0",
    "@steipete/bird": "^0.8.0",
    "NeteaseCloudMusicApi": "^4.29.0",
    "asciichart": "^1.5.25",
    "cheerio": "^1.2.0",
    "elysia": "latest",
    "es-module-lexer": "^2.0.0",
    "grammy": "^1.40.0",
    "hyparquet": "^1.25.1",
    "mathjs": "^15.1.1",
    "nice-grpc": "^2.1.14",
    "openai": "^6.22.0",
    "playwright": "^1.58.2",
    "protobufjs": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "bun-types": "latest",
    "concurrently": "^9.2.1",
    "grpc-tools": "^1.13.1",
    "ts-proto": "^2.11.4"
  },
  "module": "src/index.js"
}
