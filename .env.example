# Shared socket settings for TS + Rust runtimes
# Copy to .env and adjust once for all services.
# If running services without sudo and /run is not writable, override to a user-writable path.

# Optional: KAIROS_ENCLAVE_SOCKET=unix:///tmp/kairos-runtime-enclave.sock
# Optional: KAIROS_VFS_SOCKET=unix:///tmp/kairos-runtime-vfs.sock
KAIROS_ENCLAVE_SOCKET=unix:///run/kairos-runtime/sockets/kairos-runtime-enclave.sock
KAIROS_VFS_SOCKET=unix:///run/kairos-runtime/sockets/kairos-runtime-vfs.sock

# Enclave API key for the LLM provider. It runs in the enclave-runtime service.
ENCLAVE_API_KEY=your_api_key
# Cloud API key for the LLM provider. It runs in the state-daemon service.
CLOUD_API_KEY=your_api_key
# Bot token for the Telegram bot.   
BOT_TOKEN=your_bot_token
# Optional: OWNER_USER_ID=your_owner_user_id

# If you are running ollama on your host, use the this value.
# Otherwise, use the default value in the docker-compose.yml file.
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional: VFS_READY_TIMEOUT_SEC=1800
